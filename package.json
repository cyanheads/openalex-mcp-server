{
  "name": "@cyanheads/openalex-mcp-server",
  "version": "0.3.0",
  "description": "Access the OpenAlex academic research catalog - 270M+ publications through MCP. STDIO & Streamable HTTP.",
  "mcpName": "io.github.cyanheads/openalex-mcp-server",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openalex-mcp-server": "dist/index.js"
  },
  "files": ["dist/", "README.md", "LICENSE", "CLAUDE.md", "Dockerfile", "server.json"],
  "scripts": {
    "build": "bun scripts/build.ts",
    "rebuild": "bun scripts/clean.ts && bun scripts/build.ts",
    "clean": "bun scripts/clean.ts",
    "devcheck": "bun scripts/devcheck.ts",
    "tree": "bun scripts/tree.ts",
    "format": "biome check --write --unsafe .",
    "lint:mcp": "bun scripts/lint-mcp.ts",
    "test": "vitest run",
    "dev:stdio": "MCP_TRANSPORT_TYPE=stdio bun --watch src/index.ts",
    "dev:http": "MCP_TRANSPORT_TYPE=http bun --watch src/index.ts",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "openalex",
    "academic-research",
    "academic-search",
    "bibliometrics",
    "citation-analysis",
    "literature-search",
    "scholarly-data",
    "scholarly-research",
    "typescript"
  ],
  "author": "cyanheads (https://github.com/cyanheads)",
  "homepage": "https://github.com/cyanheads/openalex-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/cyanheads/openalex-mcp-server/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/openalex-mcp-server.git"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.11",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.2.8",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^25.5.0",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
